              "path": ["invitados", ""]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('La respuesta es un array', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json).to.be.an('array');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Crear Invitado",
          "id": "ddee4455-ff66-0077-1188-2299001122bb",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Test Newman\",\n  \"email\": \"newman@test.com\",\n  \"estado\": \"pendiente\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/invitados/",
              "host": ["{{baseUrl}}"],
              "path": ["invitados", ""]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200 o 201', function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});",
                  "pm.test('Tiene campo id', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json).to.have.property('id');",
                  "    pm.collectionVariables.set('invitado_id', json.id);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Actualizar Invitado",
          "id": "eeff5566-0077-1188-2299-33aa001133cc",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"estado\": \"confirmado\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/invitados/{{invitado_id}}/estado",
              "host": ["{{baseUrl}}"],
              "path": ["invitados", "{{invitado_id}}", "estado"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Estado actualizado a confirmado', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.estado).to.eql('confirmado');",
                  "});"
                ]
              }
            }
          ]
        },
