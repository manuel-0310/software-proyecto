      "item": [
        {
          "name": "Login Exitoso",
          "id": "aabb1122-cc33-dd44-ee55-ff6677889900",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"weddy2024\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Tiene access_token', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json).to.have.property('access_token');",
                  "    pm.collectionVariables.set('token', json.access_token);",
                  "});"
                ]
              }
            }
          ]
        },
